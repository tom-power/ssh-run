#compdef sshRun

_hosts() {
  compadd $(sshRun hosts | sed 's/echo//')
}

_commands() {
  compadd $(sshRun "${words[2]}" commands | sed 's/echo//')
}

_arguments -s \
  '1:hosts:_hosts' \
  '2:commands:_commands' \
  '3:explainCommand:->explainCommand'

if [[ $state == 'explainCommand' && ${line[2]} != "explain" ]]; then
  _arguments '3:explainCommand:(explain)'
fi